---
layout: layout.njk
---
<div class="ast-container" style="padding: 40px 20px;">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
        {% if image %}
        <img src="{{ image }}" alt="{{ title }}" style="max-width: 100%; max-height: 400px; margin-bottom: 30px; border-radius: 10px;">
        {% endif %}
        <h1 style="color: var(--ast-global-color-0); margin-bottom: 20px;">{{ title }}</h1>
        <p style="font-size: 1.2rem; color: var(--ast-global-color-3); margin-bottom: 40px; font-style: italic;">{{ description }}</p>
        
        <div style="text-align: left; line-height: 1.8; color: var(--ast-global-color-3);">
            {{ content | safe }}
        </div>
        
        <div style="margin-top: 50px;">
            <a href="/product/" style="display: inline-block; padding: 10px 20px; background-color: var(--ast-global-color-0); color: #fff; text-decoration: none; border-radius: 5px;">&larr; Back to Products</a>
        </div>
    </div>
</div>
